{
    "name": "ahmed-bhs/pyra",
    "description": "Standalone CLI that validates the shape of your test pyramid (unit/integration/e2e ratios) for any PHP project.",
    "type": "library",
    "license": "MIT",
    "keywords": ["test", "testing", "test-pyramid", "phpunit", "quality", "ci"],
    "authors": [
        {
            "name": "Ahmed EBEN HASSINE"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/finder": "^6.4 || ^7.0",
        "symfony/yaml": "^6.4 || ^7.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "AhmedBhs\\Pyra\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AhmedBhs\\Pyra\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/pyra"],
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse"
    }
}
